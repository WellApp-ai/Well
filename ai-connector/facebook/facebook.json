{
  "meta": {
    "schemaVersion": "1.0.0"
  },
  "data": {
    "type": "blueprint",
    "attributes": {
      "getDocuments": [
        {
          "action": "goToUrl",
          "url": "https://business.facebook.com/latest/billing_hub/payment_activity"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "wait",
          "seconds": 3
        },
        {
          "action": "forEach",
          "id": "transaction-rows",
          "on": {
            "querySelector": "[role='row']"
          },
          "selectorStrategies": [
            {
              "strategy": "aria-role",
              "value": "[role='row']"
            },
            {
              "strategy": "css",
              "value": "table tbody tr"
            },
            {
              "strategy": "css",
              "value": "[data-testid*='transaction']"
            }
          ],
          "steps": [
            {
              "action": "click"
            },
            {
              "action": "waitForNetworkIdle"
            },
            {
              "action": "wait",
              "seconds": 2
            },
            {
              "action": "startDownloadInterception"
            },
            {
              "action": "click",
              "querySelector": "a[href*='download'], a[href*='receipt'], a[href*='invoice'], button:has(svg path[d*='arrow']), [aria-label*='ownload']",
              "selectorStrategies": [
                {
                  "strategy": "href-pattern",
                  "value": "a[href*='download']"
                },
                {
                  "strategy": "href-pattern",
                  "value": "a[href*='receipt']"
                },
                {
                  "strategy": "href-pattern",
                  "value": "a[href*='invoice']"
                },
                {
                  "strategy": "css",
                  "value": "[data-testid*='download']"
                }
              ],
              "timeout": 5000
            },
            {
              "action": "wait",
              "seconds": 3
            },
            {
              "action": "stopDownloadInterception",
              "outputVariable": "new_pdfs"
            },
            {
              "action": "mergeVariables",
              "inputVariable": "new_pdfs",
              "outputVariable": "all_pdfs"
            },
            {
              "action": "goBack"
            },
            {
              "action": "waitForNetworkIdle"
            },
            {
              "action": "wait",
              "seconds": 1
            }
          ]
        },
        {
          "action": "downloadPdfsFromUrls",
          "inputVariable": "all_pdfs"
        }
      ],
      "checkAuth": [
        {
          "action": "goToUrl",
          "url": "https://business.facebook.com/latest/billing_hub/payment_activity"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "checkAuth",
          "authSelector": "a[href*='billing_hub/payment_activity']",
          "timeout": 10000
        }
      ]
    }
  }
}