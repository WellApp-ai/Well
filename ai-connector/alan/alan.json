{
  "meta": {
    "schemaVersion": "1.0.0"
  },
  "data": {
    "type": "blueprint",
    "attributes": {
      "checkAuth": [
        {
          "action": "goToUrl",
          "url": "https://alan.com/app/new-dashboard/insurance#individualProfile/accounting"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "wait",
          "seconds": 3
        },
        {
          "action": "checkAuth",
          "authSelector": "table tbody",
          "timeout": 10000
        }
      ],
      "getDocuments": [
        {
          "action": "goToUrl",
          "url": "https://alan.com/app/new-dashboard/insurance#individualProfile/accounting"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "wait",
          "seconds": 3
        },
        {
          "action": "startNetworkInspection"
        },
        {
          "action": "forEach",
          "id": "invoice-rows",
          "optional": true,
          "on": {
            "querySelector": "table tbody tr"
          },
          "maxItems": 3,
          "steps": [
            {
              "action": "click",
              "querySelector": "button:has(svg path[d^='M8.069'])"
            },
            {
              "action": "wait",
              "seconds": 3
            }
          ]
        },
        {
          "action": "findPdfFromNetworkInspection",
          "outputVariable": "all_pdfs"
        },
        {
          "action": "downloadPdfsFromUrlWithHeaders",
          "inputVariable": "all_pdfs"
        }
      ]
    }
  }
}