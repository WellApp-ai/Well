{
  "meta": {
    "schemaVersion": "1.0.0"
  },
  "data": {
    "type": "blueprint",
    "attributes": {
      "getDocuments": [
        {
          "action": "goToUrl",
          "url": "https://hpanel.hostinger.com/billing/payment-history/paid"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "wait",
          "seconds": 2
        },
        {
          "action": "forEach",
          "id": "invoice-items",
          "on": {
            "querySelector": ".h-payment-history-item__details-link > a"
          },
          "selectorStrategies": [
            {
              "strategy": "css",
              "value": ".h-payment-history-item__details-link > a"
            },
            {
              "strategy": "css",
              "value": ".h-payment-history-item a.h-button-v2"
            },
            {
              "strategy": "aria-role",
              "value": "a[aria-label*='details']"
            }
          ],
          "steps": [
            {
              "action": "click"
            },
            {
              "action": "waitForNetworkIdle"
            },
            {
              "action": "wait",
              "seconds": 1
            },
            {
              "action": "startDownloadInterception"
            },
            {
              "action": "click",
              "querySelector": ".h-payment-history-details__actions button.h-button-v2",
              "selectorStrategies": [
                {
                  "strategy": "css",
                  "value": ".h-payment-history-details__actions button.h-button-v2"
                },
                {
                  "strategy": "css",
                  "value": ".h-payment-history-details__actions button"
                }
              ]
            },
            {
              "action": "wait",
              "seconds": 3
            },
            {
              "action": "stopDownloadInterception",
              "outputVariable": "new_pdfs"
            },
            {
              "action": "mergeVariables",
              "inputVariable": "new_pdfs",
              "outputVariable": "all_pdfs"
            },
            {
              "action": "goBack"
            },
            {
              "action": "waitForNetworkIdle"
            },
            {
              "action": "wait",
              "seconds": 1
            }
          ]
        },
        {
          "action": "downloadPdfsFromUrls",
          "inputVariable": "all_pdfs"
        }
      ],
      "checkAuth": [
        {
          "action": "goToUrl",
          "url": "https://hpanel.hostinger.com/billing/payment-history/paid"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "checkAuth",
          "authSelector": ".h-billing-payment-history-paid",
          "timeout": 10000
        }
      ]
    }
  }
}