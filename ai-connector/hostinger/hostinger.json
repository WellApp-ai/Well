{
  "meta": {
    "schemaVersion": "1.0.0"
  },
  "data": {
    "type": "blueprint",
    "attributes": {
      "getDocuments": [
        {
          "action": "goToUrl",
          "url": "https://hpanel.hostinger.com/billing/payment-history/paid"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "wait",
          "seconds": 2
        },
        {
          "action": "forEach",
          "id": "invoice-items",
          "on": {
            "querySelector": "a[href*='/billing/payment-history/paid/H_']"
          },
          "selectorStrategies": [
            {
              "strategy": "href-pattern",
              "value": "a[href*='/billing/payment-history/paid/H_']"
            },
            {
              "strategy": "css",
              "value": "a.h-hyperlink.h-hyperlink--button[href*='/payment-history/paid/']"
            }
          ],
          "steps": [
            {
              "action": "click"
            },
            {
              "action": "waitForNetworkIdle"
            },
            {
              "action": "wait",
              "seconds": 1
            },
            {
              "action": "startDownloadInterception"
            },
            {
              "action": "click",
              "querySelector": "div.h-payment-history-details__actions button.h-button-v2",
              "selectorStrategies": [
                {
                  "strategy": "css",
                  "value": "div.h-payment-history-details__actions button.h-button-v2"
                },
                {
                  "strategy": "css",
                  "value": "div.h-payment-history-details button[class*='button']"
                }
              ],
              "timeout": 5000
            },
            {
              "action": "wait",
              "seconds": 3
            },
            {
              "action": "stopDownloadInterception",
              "outputVariable": "new_pdfs"
            },
            {
              "action": "mergeVariables",
              "inputVariable": "new_pdfs",
              "outputVariable": "all_pdfs"
            },
            {
              "action": "goBack"
            },
            {
              "action": "waitForNetworkIdle"
            },
            {
              "action": "wait",
              "seconds": 1
            }
          ]
        },
        {
          "action": "downloadPdfsFromUrls",
          "inputVariable": "all_pdfs"
        }
      ],
      "checkAuth": [
        {
          "action": "goToUrl",
          "url": "https://hpanel.hostinger.com/billing/payment-history/paid"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "checkAuth",
          "authSelector": "div.h-billing-payment-history-paid",
          "timeout": 10000
        }
      ]
    }
  }
}