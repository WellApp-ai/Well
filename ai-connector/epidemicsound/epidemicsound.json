{
  "meta": {
    "schemaVersion": "1.0.0"
  },
  "data": {
    "type": "blueprint",
    "attributes": {
      "getDocuments": [
        {
          "action": "goToUrl",
          "url": "https://www.epidemicsound.com/account/subscriptions"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "wait",
          "seconds": 2
        },
        {
          "action": "paginationLoop",
          "id": "receipts-pagination",
          "nextSelector": "[class*='pageList'] a[class*='index']:last-of-type:not([class*='paginationActive'])",
          "disabledSelector": "[class*='pageList'] a[class*='index']:last-of-type[class*='paginationActive']",
          "maxPages": 50,
          "steps": [
            {
              "action": "forEach",
              "id": "receipt-rows",
              "optional": true,
              "on": {
                "querySelector": "tr[class*='bodyRow']"
              },
              "selectorStrategies": [
                {
                  "strategy": "css",
                  "value": "tr[class*='bodyRow']"
                },
                {
                  "strategy": "css",
                  "value": "tr[class*='_bodyRow_']"
                }
              ],
              "steps": [
                {
                  "action": "startDownloadInterception"
                },
                {
                  "action": "click",
                  "querySelector": "button",
                  "timeout": 5000
                },
                {
                  "action": "wait",
                  "seconds": 3
                },
                {
                  "action": "stopDownloadInterception",
                  "outputVariable": "new_pdfs"
                },
                {
                  "action": "mergeVariables",
                  "inputVariable": "new_pdfs",
                  "outputVariable": "all_pdfs"
                }
              ]
            }
          ]
        },
        {
          "action": "downloadPdfsFromUrls",
          "inputVariable": "all_pdfs"
        }
      ],
      "checkAuth": [
        {
          "action": "goToUrl",
          "url": "https://www.epidemicsound.com/account/subscriptions"
        },
        {
          "action": "waitForNetworkIdle"
        },
        {
          "action": "checkAuth",
          "authSelector": "a[href*='/account/subscriptions']",
          "timeout": 10000
        }
      ]
    }
  }
}